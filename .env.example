# Plantilla de variables de entorno. Cópiala a .env y ajusta los valores:
#   cp .env.example .env   (Linux/Mac)
#   copy .env.example .env (Windows)

# Clave de cifrado de n8n. En local cualquier string sirve; en prod usa una aleatoria.
N8N_ENCRYPTION_KEY=change-me-to-a-random-string

# URL de la API a la que el workflow de n8n hace el POST.
# Local: el contenedor "api" del compose.
# Para la demo con AWS, reemplaza por tu URL pública, ej: https://tu-api.aws.com/webhook
API_WEBHOOK_URL=http://api:8000/webhook
